# Get your Tavily API key at: https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Get your Groq API key at: https://console.groq.com
GROQ_API_KEY=gsk_your-key-here

# ── LangSmith Tracing (optional but recommended) ──────────────────────────────
# Get your API key at: https://smith.langchain.com
# Set LANGCHAIN_TRACING_V2=true to enable full tracing of every node,
# every Tavily call, and every LLM decision with latency and token usage.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your-key-here
LANGCHAIN_PROJECT=agentcorp
